# ================================================================
# ShieldPay Environment Variables
# COPY this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore
# ================================================================

# ── Frontend (Vite — must prefix with VITE_) ──────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Supabase Edge Functions (set via: supabase secrets set) ───
# These are NOT in .env — set them in Supabase dashboard
# or via CLI: supabase secrets set KEY=value

# ── KCB Buni — M-Pesa B2B/B2C payments ───────────────────────
# Get from: https://developer.kcbgroup.com
BUNI_ENV=sandbox
BUNI_CLIENT_ID=
BUNI_CLIENT_SECRET=
BUNI_SHORTCODE=
BUNI_PASSKEY=

# ── Stanbic PesaLink — bank-to-bank transfers ─────────────────
# Get from: Stanbic Bank developer portal
STANBIC_ENV=sandbox
STANBIC_CLIENT_ID=
STANBIC_CLIENT_SECRET=
STANBIC_ACCOUNT_NO=

# ── QuickBooks Online (optional sync) ─────────────────────────
# Get from: https://developer.intuit.com
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=https://YOUR_REF.supabase.co/functions/v1/accounting-sync/oauth/callback/quickbooks
QB_ENV=sandbox
QB_WEBHOOK_VERIFIER_TOKEN=

# ── Zoho Books (optional sync) ────────────────────────────────
# Get from: https://api-console.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=https://YOUR_REF.supabase.co/functions/v1/accounting-sync/oauth/callback/zoho

# ── Africa's Talking — SMS + WhatsApp ─────────────────────────
# Get from: https://account.africastalking.com
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=ShieldPay

# ── SendGrid — Email ──────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@shieldpay.ke

# ── Sync security ─────────────────────────────────────────────
TOKEN_ENCRYPT_KEY=generate-32-random-chars-here-now
APP_URL=https://your-app.vercel.app
CRON_SECRET=generate-another-random-secret-here
